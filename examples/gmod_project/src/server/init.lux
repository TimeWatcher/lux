import { buildHud } from "hud"
import { netx } from "@lux/gmod"
import macro { defineNetReceiver } from "@lux/gmod/macros"

netx.register("lux:announce_hud")

defineNetReceiver("lux:request_hud", (len, ply) => {
    local hud = buildHud(0, { ply })
    print(hud.text)
})

export fn announce(players, ...) {
  local hud = buildHud(0, players, ...)
  print(hud.text)

  netx.broadcast("lux:announce_hud", () => net.WriteString(hud.text))
}
